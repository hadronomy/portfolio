    "prettier-plugin-astro": "catalog:lint",
    "taze": "catalog:cli",
    "turbo": "catalog:monorepo"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "bun biome check --write --no-errors-on-unmatched"
    ]

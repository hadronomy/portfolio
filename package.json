{
  "name": "@hadronomy/portfolio",
  "private": true,
  "engines": {
    "node": ">=20.18.0"
  },
  "packageManager": "bun@1.3.13",
  "scripts": {
    "prepare": "husky",
    "format": "bun biome format --write .; bun prettier --write .",
    "lint": "bun biome lint --apply .",
    "lint:ws": "bunx sherif@latest",
    "ci": "bun biome check --write --no-errors-on-unmatched",
    "update:plan": "bun taze",
    "update:write": "bun taze --write"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:lint",
    "@commitlint/cli": "catalog:lint",
